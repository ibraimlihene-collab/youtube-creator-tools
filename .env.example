# ============================================================
# SERVER-SIDE SECRETS ONLY — never commit real values
# Copy to .env (gitignored) and fill on your machine / Netlify UI
# ============================================================

# Google Gemini / AI Studio (server only)
GEMINI_API_KEY=

# Apify token (server only)
APIFY_TOKEN=

# Optional: Netlify deploy token — CLI only, never ship to browser
# NETLIFY_AUTH_TOKEN=

# Comma-separated allowed origins (production domain)
ALLOWED_ORIGINS=https://youtube-creator-tools.netlify.app,http://localhost:5173,http://localhost:8888

# Rate limit: max AI requests per IP per minute
RATE_LIMIT_PER_MINUTE=20

# Optional shared secret the SPA sends as X-App-Token (set same value in Netlify + VITE_ only if you accept public SPA token; prefer leaving empty and relying on origin + rate limit)
APP_REQUEST_SECRET=
